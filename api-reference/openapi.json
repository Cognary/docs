{
  "openapi": "3.1.0",
  "info": {
    "title": "Aionis API",
    "version": "v1",
    "description": "Public API surface for Aionis memory, policy, replay, and sandbox workflows."
  },
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "servers": [
    {
      "url": "https://api.aionis.com",
      "description": "Production (replace with your deployed base URL)"
    },
    {
      "url": "http://localhost:3001",
      "description": "Local development"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    },
    {
      "BearerAuth": []
    },
    {
      "AdminTokenAuth": []
    }
