  "paths": {
    "/v1/memory/write": {
      "post": {
        "tags": [
          "Memory"
        ],
        "summary": "Write memory nodes and edges",
        "description": "Writes memory nodes/edges and returns a traceable commit reference.",
        "operationId": "memoryWrite",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WriteRequest"
              },
              "examples": {
                "default": {
                  "value": {
                    "tenant_id": "default",
                    "scope": "support",
                    "input_text": "User asked for invoice copy",
                    "memory_lane": "shared",
                    "nodes": [
                      {
                        "type": "event",
                        "memory_lane": "shared",
                        "text_summary": "User asked for invoice copy"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Write accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WriteResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "501": {
            "$ref": "#/components/responses/Unsupported"
          }
        }
      }
    },
